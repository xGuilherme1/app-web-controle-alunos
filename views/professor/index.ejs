<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/professor/create" class="btn btn-primary">+ Novo Professor</a>
  </div>
</div>

<div class="data-panel">
  <div class="table-responsive">
    <table class="table table-hover data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Titulacao</th>
          <th class="actions-cell">Acoes</th>
        </tr>
      </thead>

      <tbody>
        <% if (professores.length === 0) { %>
          <tr>
            <td colspan="4" class="empty-state">Nenhum professor cadastrado.</td>
          </tr>
        <% } %>

        <% professores.forEach(professor => { %>
          <tr>
            <td><%= professor.id_pro %></td>
            <td><strong><%= professor.nome_pro %></strong></td>
            <td><%= professor.titulacao_pro %></td>
            <td class="actions-cell">
              <div class="action-group">
                <a href="/professor/view/<%= professor.id_pro %>" class="btn btn-sm btn-outline-secondary">Ver</a>
                <a href="/professor/edit/<%= professor.id_pro %>" class="btn btn-sm btn-outline-primary">Editar</a>

                <form action="/professor/delete/<%= professor.id_pro %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
