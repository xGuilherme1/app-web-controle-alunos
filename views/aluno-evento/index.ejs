<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/aluno-evento/create" class="btn btn-primary">+ Novo Vinculo</a>
  </div>
</div>

<div class="data-panel">
  <div class="table-responsive">
    <table class="table table-hover data-table">
      <thead>
        <tr>
          <th>Aluno</th>
          <th>Evento</th>
          <th>Presenca</th>
          <th class="actions-cell">Acoes</th>
        </tr>
      </thead>

      <tbody>
        <% if (vinculos.length === 0) { %>
          <tr>
            <td colspan="4" class="empty-state">Nenhum vinculo cadastrado.</td>
          </tr>
        <% } %>

        <% vinculos.forEach(vinculo => { %>
          <tr>
            <td><strong><%= vinculo.aluno?.nome_alu || '-' %></strong></td>
            <td><%= vinculo.evento?.titulo_eve || '-' %></td>
            <td><%= vinculo.presenca ? 'Sim' : 'Nao' %></td>
            <td class="actions-cell">
              <div class="action-group">
                <a href="/aluno-evento/view/<%= vinculo.alunoId %>/<%= vinculo.eventoId %>" class="btn btn-sm btn-outline-secondary">Ver</a>
                <a href="/aluno-evento/edit/<%= vinculo.alunoId %>/<%= vinculo.eventoId %>" class="btn btn-sm btn-outline-primary">Editar</a>
                <form action="/aluno-evento/delete/<%= vinculo.alunoId %>/<%= vinculo.eventoId %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
