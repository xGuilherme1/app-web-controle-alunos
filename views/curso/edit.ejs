<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/curso" class="btn btn-outline-secondary">Voltar</a>
  </div>
</div>

<div class="form-panel">
  <form action="/curso/edit/<%= curso.id_cur %>" method="POST">
    <div class="mb-3">
      <label for="nome_cur" class="form-label">Nome</label>
      <input
        type="text"
        id="nome_cur"
        name="nome_cur"
        class="form-control"
        maxlength="100"
        value="<%= curso.nome_cur %>"
        required
      >
    </div>

    <div class="mb-3">
      <label for="carga_horaria_cur" class="form-label">Carga Horaria</label>
      <input
        type="number"
        id="carga_horaria_cur"
        name="carga_horaria_cur"
        class="form-control"
        min="1"
        value="<%= curso.carga_horaria_cur %>"
        required
      >
    </div>

    <div class="mb-3">
      <label for="departamento" class="form-label">Departamento</label>
      <select id="departamento" name="departamento" class="form-select" required>
        <option value="">Selecione um departamento</option>
        <% departamentos.forEach(departamento => { %>
          <option
            value="<%= departamento.id_dep %>"
            <%= curso.departamento?.id_dep === departamento.id_dep ? 'selected' : '' %>
          >
            <%= departamento.nome_dep %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="page-actions">
      <button type="submit" class="btn btn-primary">Salvar</button>
      <a href="/curso" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
