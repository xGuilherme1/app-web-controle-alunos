<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/aluno-disciplina" class="btn btn-outline-secondary">Voltar</a>
    <a href="/aluno-disciplina/edit/<%= vinculo.alunoId %>/<%= vinculo.disciplinaId %>" class="btn btn-primary">Editar</a>
  </div>
</div>

<div class="details-panel">
  <dl class="details-list">
    <dt>Aluno</dt>
    <dd><%= vinculo.aluno?.nome_alu || '-' %></dd>

    <dt>Disciplina</dt>
    <dd><%= vinculo.disciplina?.nome_dis || '-' %></dd>

    <dt>Nota</dt>
    <dd><%= vinculo.nota ?? '-' %></dd>
  </dl>
</div>
