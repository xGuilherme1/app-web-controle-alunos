<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/aluno" class="btn btn-outline-secondary">Voltar</a>
    <a href="/aluno/edit/<%= aluno.id_alu %>" class="btn btn-primary">Editar</a>
  </div>
</div>

<div class="details-panel">
  <dl class="details-list">
    <dt>ID</dt>
    <dd><%= aluno.id_alu %></dd>

    <dt>Nome</dt>
    <dd><%= aluno.nome_alu %></dd>

    <dt>Nascimento</dt>
    <dd><%= dateFormat(aluno.data_nascimento_alu) %></dd>

    <dt>Curso</dt>
    <dd><%= aluno.curso?.nome_cur || '-' %></dd>

    <dt>Turma</dt>
    <dd><%= aluno.turma ? `${aluno.turma.nome_tur} - ${aluno.turma.ano_tur}` : '-' %></dd>

    <dt>Endereco</dt>
    <dd><%= aluno.endereco ? `${aluno.endereco.logradouro_end}, ${aluno.endereco.numero_end} - ${aluno.endereco.cidade_end}` : '-' %></dd>
  </dl>
</div>
