<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/disciplina/create" class="btn btn-primary">+ Nova Disciplina</a>
  </div>
</div>

<div class="data-panel">
  <div class="table-responsive">
    <table class="table table-hover data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Professor</th>
          <th class="actions-cell">Acoes</th>
        </tr>
      </thead>

      <tbody>
        <% if (disciplinas.length === 0) { %>
          <tr>
            <td colspan="4" class="empty-state">Nenhuma disciplina cadastrada.</td>
          </tr>
        <% } %>

        <% disciplinas.forEach(disciplina => { %>
          <tr>
            <td><%= disciplina.id_dis %></td>
            <td><strong><%= disciplina.nome_dis %></strong></td>
            <td><%= disciplina.professor?.nome_pro || '-' %></td>
            <td class="actions-cell">
              <div class="action-group">
                <a href="/disciplina/view/<%= disciplina.id_dis %>" class="btn btn-sm btn-outline-secondary">Ver</a>
                <a href="/disciplina/edit/<%= disciplina.id_dis %>" class="btn btn-sm btn-outline-primary">Editar</a>
                <form action="/disciplina/delete/<%= disciplina.id_dis %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
