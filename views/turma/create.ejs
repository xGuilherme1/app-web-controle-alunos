<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/turma" class="btn btn-outline-secondary">Voltar</a>
  </div>
</div>

<div class="form-panel">
  <form action="/turma/create" method="POST">
    <div class="mb-3">
      <label for="nome_tur" class="form-label">Nome</label>
      <input
        type="text"
        id="nome_tur"
        name="nome_tur"
        class="form-control"
        maxlength="150"
        required
      >
    </div>

    <div class="mb-3">
      <label for="ano_tur" class="form-label">Ano</label>
      <input
        type="number"
        id="ano_tur"
        name="ano_tur"
        class="form-control"
        min="1900"
        max="2100"
        required
      >
    </div>

    <div class="page-actions">
      <button type="submit" class="btn btn-primary">Salvar</button>
      <a href="/turma" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
