<div class="page-header">
  <h1><%= titulo %></h1>

  <div class="page-actions">
    <a href="/ocorrencia" class="btn btn-outline-secondary">Voltar</a>
    <a href="/ocorrencia/edit/<%= ocorrencia.id_oco %>" class="btn btn-primary">Editar</a>
  </div>
</div>

<div class="details-panel">
  <dl class="details-list">
    <dt>ID</dt>
    <dd><%= ocorrencia.id_oco %></dd>

    <dt>Tipo</dt>
    <dd><%= ocorrencia.tipo_oco %></dd>

    <dt>Data</dt>
    <dd><%= dateFormat(ocorrencia.data_oco) %></dd>

    <dt>Aluno</dt>
    <dd><%= ocorrencia.aluno?.nome_alu || '-' %></dd>

    <dt>Descricao</dt>
    <dd><%= ocorrencia.descricao_oco %></dd>
  </dl>
</div>
